#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."

# Mark the necessary Go modules as private to avoid Go's proxy
export GOPRIVATE="${GOPRIVATE:+$GOPRIVATE,}github.com/andreibesleaga/ocm-go,github.com/stainless-sdks/ocm-go"

REPLACEMENT="${1:-"../ocm-go"}"
echo "==> Replacing Go SDK with $REPLACEMENT"
if [[ -d "$REPLACEMENT" ]] || go list -m "$REPLACEMENT" >/dev/null; then
    go mod edit -replace github.com/andreibesleaga/ocm-go="$REPLACEMENT"
    go mod tidy -e
else
    echo "Skipping Go SDK replacement (branch may not exist on Go SDK)"
fi
